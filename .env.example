# ============================================================
# StockTradebyZ 环境变量配置
# 使用说明: cp .env.example .env && 编辑 .env 填入实际值
# ============================================================

# ----------------------
# 必填项 (启动前必须配置)
# ----------------------

# Tushare API Token (必填，用于获取股票行情数据)
# 注册地址: https://tushare.pro/register
TUSHARE_TOKEN=

# ----------------------
# 服务端口与地址
# ----------------------

# 后端服务绑定地址
BACKEND_HOST=0.0.0.0

# 后端服务端口
BACKEND_PORT=8000

# 前端开发服务绑定地址
FRONTEND_HOST=0.0.0.0

# 前端开发服务端口
FRONTEND_PORT=5173

# 前端 API 请求地址 (留空则自动拼接为 http://127.0.0.1:{BACKEND_PORT}/api)
VITE_API_BASE_URL=

# 后端 CORS 允许的来源 (逗号分隔)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ----------------------
# LLM API Keys (可选，用于 AI 选股分析)
# ----------------------

# 智谱 AI (GLM) API Key
ZHIPUAI_API_KEY=

# 阿里云 Dashscope (通义千问) API Key
DASHSCOPE_API_KEY=

# Google Gemini API Key
GEMINI_API_KEY=

# ----------------------
# 分析策略配置
# ----------------------

# 默认分析策略: quant | glm | qwen | gemini
DEFAULT_REVIEWER=quant

# 最低评分阈值 (低于此分数的候选股将被过滤)
MIN_SCORE_THRESHOLD=4.0

# ----------------------
# Tushare 请求频率控制
# ----------------------

# 频率限制窗口 (秒)
TUSHARE_RATE_LIMIT_WINDOW_SECONDS=60

# 每个窗口内最大请求数
TUSHARE_MAX_REQUESTS_PER_MINUTE=800

# ----------------------
# 包管理器镜像源 (安装阶段使用)
# ----------------------

# pip 镜像源
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# apt 镜像源（用于 Docker 构建）
APT_MIRROR=mirrors.tuna.tsinghua.edu.cn

# 是否安装编译工具链（仅当某些 Python 包无预编译 wheel 时启用）
INSTALL_BUILD_DEPS=0

# npm 镜像源
NPM_REGISTRY=https://registry.npmmirror.com

# nginx 基础镜像（Docker Hub 超时时可改为镜像站或私有仓库完整地址）
NGINX_BASE_IMAGE=nginx:1.27-alpine

# ----------------------
# 认证与安全
# ----------------------

# JWT 密钥 (生产环境必须更改为随机强字符串)
SECRET_KEY=change-me-in-production

# JWT Token 过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认管理员账号
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# 注册验证问题与答案
REGISTER_VALIDATION_QUESTION=系统管理员的微信名是什么
REGISTER_VALIDATION_ANSWER=船长

# 运行环境: development | production
ENVIRONMENT=development

# ----------------------
# PostgreSQL 配置 (正式主库)
# ----------------------

# 数据库 URL - PostgreSQL 作为正式主库
# Docker 环境下会自动启动 PostgreSQL 服务
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://stocktrade:stocktrade123@postgres:5432/stocktrade

# PostgreSQL 配置
POSTGRES_DB=stocktrade
POSTGRES_USER=stocktrade
POSTGRES_PASSWORD=stocktrade123
POSTGRES_PORT=5432

# ----------------------
# Redis 缓存配置
# ----------------------

# Redis 连接 URL (留空则使用下面分开的配置)
# 格式: redis://[:password@]host:port/db
# Docker 环境: redis://:redis_password@redis:6379/0
REDIS_URL=

# Redis 分开配置 (当 REDIS_URL 留空时使用)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=stocktrade_redis_123

# 本地开发时可使用: redis://:stocktrade_redis_123@localhost:6379/0

# ----------------------
# 生产部署配置
# ----------------------

# 运行环境 (生产必须设为 production)
# ENVIRONMENT=production

# CORS 允许的域名 (生产环境必须设置你的域名)
# BACKEND_CORS_ORIGINS=https://stock.yourdomain.com

# JWT 密钥 (生产环境必须更改为强随机字符串)
# SECRET_KEY=your-strong-random-secret-key-here
