# 构建阶段
FROM node:20-bookworm-slim AS builder

WORKDIR /app

# 复制依赖文件
COPY frontend/package*.json /app/

# 安装依赖
RUN npm ci

# 复制源代码
COPY frontend/ /app/

# 构建项目
RUN npm run build

# 生产阶段
FROM nginx:1.27-alpine

# 复制构建产物
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
